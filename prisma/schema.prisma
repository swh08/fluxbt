// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String?
  timezone     String   @default("Australia/Sydney")
  servers      ServerConnection[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServerConnection {
  id                   String                    @id @default(cuid())
  userId               String
  name                 String
  type                 String
  protocol             String                    @default("http")
  host                 String
  port                 Int
  username             String
  password             String
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  dailyUploadSnapshots DailyUploadSnapshot[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, protocol, host, port])
}

model DailyUploadSnapshot {
  id            String   @id @default(cuid())
  serverId      String
  timezone      String   @default("Australia/Sydney")
  dateKey       String
  peerStates    String   @default("{}")
  countryTotals String   @default("{}")
  countryNames  String   @default("{}")
  trackerTotals String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  server ServerConnection @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, timezone, dateKey])
}
